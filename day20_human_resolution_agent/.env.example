OPENAI_API_KEY=replace_with_your_real_key
OPENAI_BASE_URL=https://your-proxy-base-url/v1
OPENAI_MODEL=gpt-4.1-mini

# 用于演示失败进入 dead letter queue
FAIL_SESSION_ID=demo-engineering-agent
FAIL_ON_RETRY=true
MAX_RETRY_COUNT=1

# 可选：影响 fallback 人工处理偏好
# balanced / requeue_first / close_first
HUMAN_DECISION_PREFERENCE=balanced
